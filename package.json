{
  "name": "gptplugins",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/extension"
  ],
  "scripts": {
    "dev:extension": "npm --workspace apps/extension run dev",
    "build:extension": "npm --workspace apps/extension run build",
    "test:extension": "npm --workspace apps/extension run test",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "test:api": "cd apps/api && pytest",
    "test": "npm run test:extension && npm run test:api"
  }
}
